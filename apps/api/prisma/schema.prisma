generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  user_id                       String                           @id @unique @db.VarChar(5)
  first_name                    String
  last_name                     String
  phone                         String?
  email                         String                           @unique
  cognito_sub                   String                           @unique @db.VarChar(255)
  cognito_username              String                           @db.VarChar(255)
  investor_account              String[]                         @default([])
  issuer_account                String[]                         @default([])
  password_changed_at           DateTime?
  created_at                    DateTime                         @default(now())
  updated_at                    DateTime                         @updatedAt
  email_verified                Boolean                          @default(false)
  roles                         UserRole[]
  access_logs                   AccessLog[]
  sent_admin_invitations        AdminInvitation[]                @relation("SentAdminInvitations")
  admin                         Admin?
  document_logs                 DocumentLog[]
  investments                   Investment[]
  sent_investor_org_invitations InvestorOrganizationInvitation[] @relation("SentInvestorOrgInvitations")
  investor_organizations        InvestorOrganization[]
  sent_issuer_org_invitations   IssuerOrganizationInvitation[]   @relation("SentIssuerOrgInvitations")
  issuer_organizations          IssuerOrganization[]
  loans                         Loan[]
  admin_notification_logs       NotificationLog[]                @relation("AdminNotificationLogs")
  notifications                 Notification[]
  onboarding_logs               OnboardingLog[]
  organization_memberships      OrganizationMember[]
  product_logs                  ProductLog[]
  regtank_onboarding            RegTankOnboarding[]
  triggered_application_guarantors ApplicationGuarantor[] @relation("ApplicationGuarantorTriggeredBy")
  security_logs                 SecurityLog[]
  notification_preferences      UserNotificationPreference[]
  sessions                      UserSession[]
  authored_review_remarks       ApplicationReviewRemark[]

  @@index([cognito_sub])
  @@map("users")
}

model Loan {
  id              String       @id @default(cuid())
  borrower_id     String
  amount          Decimal      @db.Decimal(18, 6)
  interest_rate   Decimal      @db.Decimal(5, 2)
  duration_months Int
  purpose         String
  status          LoanStatus   @default(DRAFT)
  funded_amount   Decimal      @default(0) @db.Decimal(18, 6)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  approved_at     DateTime?
  funded_at       DateTime?
  investments     Investment[]
  borrower        User         @relation(fields: [borrower_id], references: [user_id])

  @@map("loans")
}

model Investment {
  id          String   @id @default(cuid())
  investor_id String
  loan_id     String
  amount      Decimal  @db.Decimal(18, 6)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  investor    User     @relation(fields: [investor_id], references: [user_id])
  loan        Loan     @relation(fields: [loan_id], references: [id])

  @@map("investments")
}

model AccessLog {
  id            String   @id @default(cuid())
  user_id       String
  event_type    String
  ip_address    String?
  user_agent    String?
  device_info   String?
  cognito_event Json?
  success       Boolean  @default(true)
  metadata      Json?
  created_at    DateTime @default(now())
  device_type   String?
  portal        String?
  user          User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
  @@index([event_type])
  @@index([portal])
  @@index([created_at])
  @@index([user_id, created_at])
  @@map("access_logs")
}

model UserSession {
  id              String    @id @default(cuid())
  user_id         String
  cognito_session String    @unique @db.VarChar(512)
  ip_address      String?
  device_info     String?
  active_role     UserRole?
  last_activity   DateTime  @default(now())
  expires_at      DateTime
  revoked_at      DateTime?
  created_at      DateTime  @default(now())
  user            User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
  @@index([cognito_session])
  @@index([expires_at])
  @@index([user_id, active_role])
  @@map("user_sessions")
}

model Admin {
  id               String    @id @default(cuid())
  user_id          String    @unique
  role_description AdminRole
  status           String    @default("ACTIVE")
  last_login       DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  user             User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@map("admins")
}

model AdminInvitation {
  id                 String    @id @default(cuid())
  email              String
  role_description   AdminRole
  token              String    @unique
  expires_at         DateTime
  accepted           Boolean   @default(false)
  accepted_at        DateTime?
  invited_by_user_id String
  created_at         DateTime  @default(now())
  invited_by         User      @relation("SentAdminInvitations", fields: [invited_by_user_id], references: [user_id])

  @@index([email])
  @@index([token])
  @@index([expires_at])
  @@map("admin_invitations")
}

model SecurityLog {
  id          String   @id @default(cuid())
  user_id     String
  event_type  String
  ip_address  String?
  user_agent  String?
  device_info String?
  metadata    Json?
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
  @@index([event_type])
  @@index([created_at])
  @@map("security_logs")
}

model OnboardingLog {
  id                       String                @id @default(cuid())
  user_id                  String
  role                     UserRole
  event_type               String
  portal                   String?
  ip_address               String?
  user_agent               String?
  device_info              String?
  device_type              String?
  metadata                 Json?
  created_at               DateTime              @default(now())
  organization_name        String?
  investor_organization_id String?
  issuer_organization_id   String?
  investor_organization    InvestorOrganization? @relation(fields: [investor_organization_id], references: [id])
  issuer_organization      IssuerOrganization?   @relation(fields: [issuer_organization_id], references: [id])
  user                     User                  @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
  @@index([role])
  @@index([event_type])
  @@index([portal])
  @@index([created_at])
  @@index([user_id, created_at])
  @@index([organization_name])
  @@index([investor_organization_id])
  @@index([issuer_organization_id])
  @@map("onboarding_logs")
}

model InvestorOrganization {
  id                            String                           @id @default(cuid())
  owner_user_id                 String
  type                          OrganizationType
  name                          String?
  registration_number           String?
  onboarding_status             OnboardingStatus                 @default(PENDING)
  onboarded_at                  DateTime?
  created_at                    DateTime                         @default(now())
  updated_at                    DateTime                         @updatedAt
  first_name                    String?
  last_name                     String?
  middle_name                   String?
  nationality                   String?
  country                       String?
  id_issuing_country            String?
  gender                        String?
  address                       String?
  date_of_birth                 DateTime?
  document_type                 String?
  document_number               String?
  phone_number                  String?
  kyc_id                        String?
  bank_account_details          Json?
  wealth_declaration            Json?
  compliance_declaration        Json?
  document_info                 Json?
  liveness_check_info           Json?
  is_sophisticated_investor     Boolean                          @default(false)
  onboarding_approved           Boolean                          @default(false)
  aml_approved                  Boolean                          @default(false)
  tnc_accepted                  Boolean                          @default(false)
  deposit_received              Boolean                          @default(false)
  ssm_approved                  Boolean                          @default(false)
  admin_approved_at             DateTime?
  kyc_response                  Json?
  sophisticated_investor_reason String?
  corporate_entities            Json?
  corporate_onboarding_data     Json?
  corporate_required_documents  Json?
  director_aml_status           Json?
  director_kyc_status           Json?
  business_aml_status           Json?
  invitations                   InvestorOrganizationInvitation[]
  owner                         User                             @relation(fields: [owner_user_id], references: [user_id], onDelete: Cascade)
  onboarding_logs               OnboardingLog[]
  members                       OrganizationMember[]
  regtank_onboarding            RegTankOnboarding[]              @relation("RegTankOnboardingToInvestorOrg")
  ctos_reports                  CtosReport[]
  ctos_party_supplements        CtosPartySupplement[]
  investor_balance              InvestorBalance?
  investor_balance_transactions InvestorBalanceTransaction[]

  @@index([owner_user_id])
  @@index([owner_user_id, type])
  @@index([onboarding_status])
  @@map("investor_organizations")
}

model IssuerOrganization {
  id                           String                         @id @default(cuid())
  owner_user_id                String
  type                         OrganizationType
  name                         String?
  registration_number          String?
  onboarding_status            OnboardingStatus               @default(PENDING)
  onboarded_at                 DateTime?
  created_at                   DateTime                       @default(now())
  updated_at                   DateTime                       @updatedAt
  first_name                   String?
  last_name                    String?
  middle_name                  String?
  nationality                  String?
  country                      String?
  id_issuing_country           String?
  gender                       String?
  address                      String?
  date_of_birth                DateTime?
  document_type                String?
  document_number              String?
  phone_number                 String?
  kyc_id                       String?
  bank_account_details         Json?
  wealth_declaration           Json?
  compliance_declaration       Json?
  document_info                Json?
  liveness_check_info          Json?
  onboarding_approved          Boolean                        @default(false)
  aml_approved                 Boolean                        @default(false)
  tnc_accepted                 Boolean                        @default(false)
  ssm_checked                  Boolean                        @default(false)
  admin_approved_at            DateTime?
  kyc_response                 Json?
  corporate_entities           Json?
  corporate_onboarding_data    Json?
  corporate_required_documents Json?
  director_aml_status          Json?
  director_kyc_status          Json?
  business_aml_status          Json?
  applications                 Application[]
  contracts                    Contract[]
  invitations                  IssuerOrganizationInvitation[]
  owner                        User                           @relation(fields: [owner_user_id], references: [user_id], onDelete: Cascade)
  onboarding_logs              OnboardingLog[]
  members                      OrganizationMember[]
  regtank_onboarding           RegTankOnboarding[]            @relation("RegTankOnboardingToIssuerOrg")
  ctos_reports                 CtosReport[]
  ctos_party_supplements       CtosPartySupplement[]

  @@index([owner_user_id])
  @@index([owner_user_id, type])
  @@index([onboarding_status])
  @@map("issuer_organizations")
}

model CtosPartySupplement {
  id                       String @id @default(cuid())
  issuer_organization_id   String?
  investor_organization_id String?
  party_key                String
  /// CTOS party onboarding: email, sent, requestId, status, sentAt, etc.
  onboarding_json          Json?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  issuer_organization   IssuerOrganization?   @relation(fields: [issuer_organization_id], references: [id], onDelete: Cascade)
  investor_organization   InvestorOrganization? @relation(fields: [investor_organization_id], references: [id], onDelete: Cascade)

  @@index([issuer_organization_id])
  @@index([investor_organization_id])
  @@map("ctos_party_supplements")
}

model CtosReport {
  id                       String @id @default(cuid())
  issuer_organization_id   String?
  investor_organization_id String?
  /// Null = company/org CTOS snapshot; non-null = RegTank subject (e.g. EOD or COD).
  subject_ref              String?               @db.Text
  fetched_at               DateTime
  created_at               DateTime              @default(now())
  updated_at               DateTime              @updatedAt
  raw_xml                  String                @db.Text
  report_html              String?               @db.Text
  summary_json             Json
  company_json             Json?
  person_json              Json?
  legal_json               Json
  ccris_json               Json
  financials_json          Json
  issuer_organization      IssuerOrganization?   @relation(fields: [issuer_organization_id], references: [id], onDelete: Restrict)
  investor_organization    InvestorOrganization? @relation(fields: [investor_organization_id], references: [id], onDelete: Restrict)

  @@index([issuer_organization_id])
  @@index([investor_organization_id])
  @@index([issuer_organization_id, fetched_at(sort: Desc)])
  @@index([investor_organization_id, fetched_at(sort: Desc)])
  @@index([issuer_organization_id, subject_ref, fetched_at(sort: Desc)])
  @@index([investor_organization_id, subject_ref, fetched_at(sort: Desc)])
  @@map("ctos_reports")
}

model Application {
  id                                  String                    @id @default(cuid())
  issuer_organization_id              String
  product_version                     Int
  review_cycle                        Int                       @default(1)
  amendment_acknowledged_workflow_ids String[]                  @default([])
  status                              ApplicationStatus         @default(DRAFT)
  last_completed_step                 Int                       @default(0)
  financing_type                      Json?
  supporting_documents                Json?
  declarations                        Json?
  created_at                          DateTime                  @default(now())
  updated_at                          DateTime                  @updatedAt
  review_and_submit                   Json?
  financing_structure                 Json?
  company_details                     Json?
  business_details                    Json?
  financial_statements                Json?
  contract_id                         String?
  submitted_at                        DateTime?
  application_revisions               ApplicationRevision[]
  application_review_events           ApplicationReviewEvent[]
  application_review_items            ApplicationReviewItem[]
  application_review_remarks          ApplicationReviewRemark[]
  application_reviews                 ApplicationReview[]
  contract                            Contract?                 @relation(fields: [contract_id], references: [id])
  issuer_organization                 IssuerOrganization        @relation(fields: [issuer_organization_id], references: [id], onDelete: Cascade)
  invoices                            Invoice[]
  application_guarantors              ApplicationGuarantor[]

  @@map("applications")
}

model ApplicationGuarantor {
  id                           String              @id @default(cuid())
  application_id               String
  client_guarantor_id          String
  position                     Int                 @default(0)
  source_data                  Json?
  guarantor_type               GuarantorType
  email                        String
  name                         String?
  ic_number                    String?
  business_name                String?
  ssm_number                   String?
  aml_status                   GuarantorAmlStatus  @default(Pending)
  aml_message_status           GuarantorAmlMessage @default(PENDING)
  last_triggered_at            DateTime?
  last_synced_at               DateTime?
  triggered_by_admin_user_id   String?             @db.VarChar(5)
  metadata                     Json?
  created_at                   DateTime            @default(now())
  updated_at                   DateTime            @updatedAt
  application                  Application         @relation(fields: [application_id], references: [id], onDelete: Cascade)
  triggered_by_admin           User?               @relation("ApplicationGuarantorTriggeredBy", fields: [triggered_by_admin_user_id], references: [user_id], onDelete: SetNull)

  @@unique([application_id, client_guarantor_id])
  @@index([application_id])
  @@index([application_id, position])
  @@index([email])
  @@map("application_guarantors")
}

model ApplicationRevision {
  id             String   @id @default(cuid())
  application_id String
  review_cycle   Int
  snapshot       Json
  submitted_at   DateTime
  created_at     DateTime @default(now())

  application Application @relation(fields: [application_id], references: [id], onDelete: Cascade)

  @@unique([application_id, review_cycle])
  @@index([application_id])
  @@map("application_revisions")
}

model ApplicationReview {
  id               String           @id @default(cuid())
  application_id   String
  status           ReviewStepStatus @default(PENDING)
  reviewer_user_id String?
  reviewed_at      DateTime?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  section          ReviewSection
  application      Application      @relation(fields: [application_id], references: [id], onDelete: Cascade)

  @@unique([application_id, section])
  @@index([application_id])
  @@map("application_reviews")
}

model ApplicationReviewItem {
  id               String           @id @default(cuid())
  application_id   String
  item_type        String
  item_id          String
  status           ReviewStepStatus @default(PENDING)
  reviewer_user_id String?
  reviewed_at      DateTime?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  application      Application      @relation(fields: [application_id], references: [id], onDelete: Cascade)

  @@unique([application_id, item_type, item_id])
  @@index([application_id])
  @@index([application_id, item_type])
  @@map("application_review_items")
}

model ApplicationReviewRemark {
  id             String      @id(map: "application_review_notes_pkey") @default(cuid())
  application_id String
  scope          String
  scope_key      String
  action_type    String
  remark         String
  author_user_id String
  submitted_at   DateTime?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  application    Application @relation(fields: [application_id], references: [id], onDelete: Cascade, map: "application_review_notes_application_id_fkey")
  author         User        @relation(fields: [author_user_id], references: [user_id], onDelete: Restrict)

  @@unique([application_id, scope, scope_key], map: "application_review_remarks_application_id_scope_scope_key_key")
  @@index([application_id, scope_key], map: "application_review_notes_application_id_scope_key_idx")
  @@index([application_id, submitted_at])
  @@map("application_review_remarks")
}

model ApplicationReviewEvent {
  id               String      @id @default(cuid())
  application_id   String
  event_type       String
  scope            String?
  scope_key        String?
  old_status       String?
  new_status       String
  reviewer_user_id String?
  remark           String?
  created_at       DateTime    @default(now())
  application      Application @relation(fields: [application_id], references: [id], onDelete: Cascade)

  @@index([application_id])
  @@index([application_id, created_at])
  @@map("application_review_events")
}

model Contract {
  id                     String             @id @default(cuid())
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt
  contract_details       Json?
  offer_details          Json?
  customer_details       Json?
  issuer_organization_id String
  status                 ContractStatus     @default(DRAFT)
  withdraw_reason        WithdrawReason?
  /// SigningCloud offer-letter workflow (pending/signed metadata; no unsigned PDF stored)
  offer_signing          Json?
  /// SigningCloud contract number for webhook lookup (unique when set)
  signing_sc_contractnum String?          @unique
  applications           Application[]
  issuer_organization    IssuerOrganization @relation(fields: [issuer_organization_id], references: [id], onDelete: Cascade)
  invoices               Invoice[]

  @@index([signing_sc_contractnum])
  @@map("contracts")
}

model Invoice {
  id              String          @id @default(cuid())
  contract_id     String?
  application_id  String
  details         Json
  offer_details   Json?
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  status          InvoiceStatus   @default(DRAFT)
  withdraw_reason WithdrawReason?
  /// SigningCloud offer-letter workflow (pending/signed metadata; no unsigned PDF stored)
  offer_signing          Json?
  /// SigningCloud contract number for webhook lookup (unique when set)
  signing_sc_contractnum String?          @unique
  application     Application     @relation(fields: [application_id], references: [id], onDelete: Cascade)
  contract        Contract?       @relation(fields: [contract_id], references: [id])

  @@index([contract_id])
  @@index([application_id])
  @@index([signing_sc_contractnum])
  @@map("invoices")
}

model Note {
  id                          String     @id @default(cuid())
  source_application_id       String
  source_contract_id          String?
  source_invoice_id           String?    @unique
  issuer_organization_id      String
  status                      NoteStatus @default(DRAFT)
  listing_status              NoteListingStatus @default(NOT_LISTED)
  funding_status              NoteFundingStatus @default(NOT_OPEN)
  servicing_status            NoteServicingStatus @default(NOT_STARTED)
  title                       String
  note_reference              String     @unique
  product_snapshot            Json?
  issuer_snapshot             Json
  paymaster_snapshot          Json?
  contract_snapshot           Json?
  invoice_snapshot            Json?
  requested_amount            Decimal    @db.Decimal(18, 6)
  target_amount               Decimal    @db.Decimal(18, 6)
  funded_amount               Decimal    @default(0) @db.Decimal(18, 6)
  minimum_funding_percent     Decimal    @default(80) @db.Decimal(5, 2)
  profit_rate_percent         Decimal?   @db.Decimal(7, 4)
  platform_fee_rate_percent   Decimal    @default(0) @db.Decimal(5, 2)
  service_fee_rate_percent    Decimal    @default(0) @db.Decimal(5, 2)
  service_fee_customer_scope  String?
  maturity_date               DateTime?
  grace_period_days           Int        @default(7)
  arrears_threshold_days      Int        @default(14)
  tawidh_rate_cap_percent     Decimal    @default(1) @db.Decimal(5, 2)
  gharamah_rate_cap_percent   Decimal    @default(9) @db.Decimal(5, 2)
  published_at                DateTime?
  funding_closed_at           DateTime?
  activated_at                DateTime?
  repaid_at                   DateTime?
  arrears_started_at          DateTime?
  default_marked_at           DateTime?
  default_marked_by_admin_user_id String?
  default_reason              String?
  metadata                    Json?
  created_at                  DateTime   @default(now())
  updated_at                  DateTime   @updatedAt
  listing                     NoteListing?
  investments                 NoteInvestment[]
  payment_schedules           NotePaymentSchedule[]
  payments                    NotePayment[]
  settlements                 NoteSettlement[]
  ledger_entries              NoteLedgerEntry[]
  events                      NoteEvent[]
  admin_actions               NoteAdminAction[]

  @@index([source_application_id])
  @@index([source_contract_id])
  @@index([issuer_organization_id])
  @@index([status])
  @@index([listing_status])
  @@index([funding_status])
  @@index([servicing_status])
  @@index([maturity_date])
  @@map("notes")
}

model NoteListing {
  id              String            @id @default(cuid())
  note_id         String            @unique
  status          NoteListingStatus @default(DRAFT)
  opens_at        DateTime?
  closes_at       DateTime?
  published_at    DateTime?
  unpublished_at  DateTime?
  visibility      String            @default("INVESTOR_MARKETPLACE")
  summary         String?
  risk_disclosure Json?
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  note            Note              @relation(fields: [note_id], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([opens_at])
  @@index([closes_at])
  @@map("note_listings")
}

model NoteInvestment {
  id                       String               @id @default(cuid())
  note_id                  String
  investor_organization_id String
  investor_user_id         String
  status                   NoteInvestmentStatus @default(COMMITTED)
  amount                   Decimal              @db.Decimal(18, 6)
  allocation_percent       Decimal              @default(0) @db.Decimal(9, 6)
  committed_at             DateTime             @default(now())
  confirmed_at             DateTime?
  released_at              DateTime?
  metadata                 Json?
  created_at               DateTime             @default(now())
  updated_at               DateTime             @updatedAt
  note                     Note                 @relation(fields: [note_id], references: [id], onDelete: Cascade)

  @@index([note_id])
  @@index([investor_organization_id])
  @@index([investor_user_id])
  @@index([status])
  @@map("note_investments")
}

/// Per-investor-organization cash available for marketplace commits (minimal interaction/testing ledger).
model InvestorBalance {
  id                       String                @id @default(cuid())
  investor_organization_id String                @unique
  available_amount         Decimal               @default(0) @db.Decimal(18, 6)
  created_at               DateTime              @default(now())
  updated_at               DateTime              @updatedAt
  investor_organization    InvestorOrganization  @relation(fields: [investor_organization_id], references: [id], onDelete: Cascade)

  @@map("investor_balances")
}

/// Append-only balance movements for audit and reconciliation of investor pool cash.
model InvestorBalanceTransaction {
  id                       String                           @id @default(cuid())
  investor_organization_id String
  direction                InvestorBalanceTransactionDirection
  amount                   Decimal                          @db.Decimal(18, 6)
  source                   InvestorBalanceTransactionSource
  note_id                  String?
  note_investment_id       String?
  metadata                 Json?
  created_at               DateTime                         @default(now())
  investor_organization    InvestorOrganization             @relation(fields: [investor_organization_id], references: [id], onDelete: Cascade)

  @@index([investor_organization_id, created_at])
  @@map("investor_balance_transactions")
}

model NotePaymentSchedule {
  id                  String                @id @default(cuid())
  note_id             String
  status              NotePaymentStatus     @default(PENDING)
  sequence            Int
  due_date            DateTime
  expected_principal  Decimal               @default(0) @db.Decimal(18, 6)
